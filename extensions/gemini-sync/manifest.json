{
  "manifest_version": 3,
  "name": "Prism Gemini Sync",
  "version": "0.1.0",
  "description": "Sync selected Gemini conversations into Prism Library.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "http://localhost:3001/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
